<!DOCTYPE html>
<html>
<head>
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>Pulse Point with Button | Connecting</title>
    <style>
        body { font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif; display: flex; flex-direction: column; justify-content: center; align-items: center; height: 100vh; background: #f3f4f6; color: #374151; margin: 0; padding: 20px; text-align: center; }
        .loader { border: 5px solid #e5e7eb; border-top: 5px solid #1A4685; border-radius: 50%; width: 50px; height: 50px; animation: spin 1s linear infinite; margin-bottom: 20px; }
        .btn { display: none; padding: 15px 30px; background: #1A4685; color: white; text-decoration: none; border-radius: 12px; font-weight: bold; font-size: 18px; box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1); margin-top: 10px; }
        @keyframes spin { 0% { transform: rotate(0deg); } 100% { transform: rotate(360deg); } }
        .fade-in { animation: fadeIn 0.5s ease-in forwards; }
        @keyframes fadeIn { from { opacity: 0; } to { opacity: 1; } }
    </style>
</head>
<body>
    <div class="loader" id="loader"></div>
    <p id="status-text">Connecting to survey...</p>
    
    <a href="#" id="manual-btn" class="btn">Start Survey</a>

    <script>
        const urlParams = new URLSearchParams(window.location.search);
        const tag = urlParams.get('tag');

        // YOUR SCRIPT URL
        const googleScriptUrl = "https://script.google.com/macros/s/AKfycbwe-qd3ltECwYLio7WfxAC7RuVx1MN2zFxmJue1AD9dHRz-_Wvd5FQA2K2nv67F6g/exec"; 

        if (tag) {
            const finalUrl = googleScriptUrl + "?tag=" + encodeURIComponent(tag);
            
            // 1. Attempt Auto-Redirect immediately
            window.location.href = finalUrl;

            // 2. If it's still here after 1.5 seconds, show the button
            setTimeout(() => {
                const btn = document.getElementById('manual-btn');
                btn.href = finalUrl;
                btn.style.display = 'inline-block';
                btn.classList.add('fade-in');
                document.getElementById('status-text').innerText = "Redirect blocked? Tap below:";
                document.getElementById('loader').style.display = 'none';
            }, 1500);

        } else {
            document.body.innerHTML = "<h3>Error</h3><p>No survey tag detected.</p>";
        }
    </script>
</body>
</html>
